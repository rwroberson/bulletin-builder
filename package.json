{
  "name": "bulletin-builder",
  "version": "0.1.0-beta.1",
  "description": "Weekly church bulletin builder",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "org.bulletinbuilder.app",
    "productName": "Bulletin Builder",
    "files": [
      "main.js",
      "preload.js",
      "bulletin-render.js",
      "bulletin-print.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "fonts/", "to": "fonts/" }
    ],
    "win": {
      "target": "zip"
    }
  }
}
